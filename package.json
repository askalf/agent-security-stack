{
  "name": "agent-security-stack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The open-source agent-security stack — warden + canon + keeper — composed into one layered defense, and exposed as a single MCP server. Part of Own Your Stack.",
  "bin": {
    "oys-mcp": "./bin/oys-mcp.mjs"
  },
  "scripts": {
    "demo": "node demo.mjs",
    "demo:mcp": "node demo/mcp-demo.mjs",
    "demo:audit": "node demo/audit-demo.mjs",
    "mcp": "node bin/oys-mcp.mjs",
    "test": "node --test"
  },
  "dependencies": {
    "@askalf/warden": "git+https://github.com/askalf/warden.git#c46ef542fe692d7bbb82fd8cd19fe70dfd5d3291",
    "@askalf/canon": "git+https://github.com/askalf/canon.git#7953b1859eefa5ad7067729aa7196d2c1c8fd0a6",
    "@askalf/keeper": "git+https://github.com/askalf/keeper.git#2f33fdd79cd3a01890a32fe7f3ff6e8d689e5cec",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "keywords": [
    "ai-agents",
    "agent-security",
    "mcp",
    "own-your-stack",
    "demo"
  ],
  "author": "Thomas Sprayberry",
  "license": "MIT",
  "repository": "github:askalf/agent-security-stack",
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@askalf/warden": "$@askalf/warden"
  }
}
