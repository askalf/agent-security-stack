{
  "name": "agent-security-stack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The open-source agent-security stack — warden + canon + keeper — composed into one layered defense, and exposed as a single MCP server. Part of Own Your Stack.",
  "bin": {
    "oys-mcp": "./bin/oys-mcp.mjs"
  },
  "scripts": {
    "demo": "node demo.mjs",
    "demo:mcp": "node demo/mcp-demo.mjs",
    "demo:audit": "node demo/audit-demo.mjs",
    "mcp": "node bin/oys-mcp.mjs",
    "test": "node --test"
  },
  "dependencies": {
    "@askalf/warden": "git+https://github.com/askalf/warden.git#68246ccfa3608a84daa15441d76ac19d78f9fd24",
    "@askalf/canon": "git+https://github.com/askalf/canon.git#68666dbef97985ff0e223526768cb20df32f780b",
    "@askalf/keeper": "git+https://github.com/askalf/keeper.git#07f2af9550db26148e5029a195b8800d3351b818",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "keywords": [
    "ai-agents",
    "agent-security",
    "mcp",
    "own-your-stack",
    "demo"
  ],
  "author": "Thomas Sprayberry",
  "license": "MIT",
  "repository": "github:askalf/agent-security-stack",
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@askalf/warden": "$@askalf/warden"
  }
}
